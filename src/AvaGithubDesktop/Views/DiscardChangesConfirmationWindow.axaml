<codewf:CodeWFWindow
    x:Class="AvaGithubDesktop.Views.DiscardChangesConfirmationWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:codewf="https://codewf.com"
    xmlns:vm="using:AvaGithubDesktop.ViewModels"
    x:DataType="vm:DiscardChangesConfirmationWindowViewModel"
    Width="520"
    Height="360"
    MinWidth="460"
    MinHeight="320"
    Background="{DynamicResource PanelBackgroundBrush}"
    CanMaximize="False"
    CanMinimize="False"
    CanResize="False"
    Icon="/Assets/app-logo.ico"
    ShowInTaskbar="False"
    TitleBarBackground="{DynamicResource ToolbarBackgroundBrush}"
    TitleBarBorderBrush="{DynamicResource ToolbarBorderBrush}"
    TitleBarForeground="{DynamicResource ToolbarTextBrush}"
    TitleBarHeight="34"
    WindowStartupLocation="CenterOwner">

    <codewf:CodeWFWindow.LeftContent>
        <TextBlock
            Margin="12,0,0,0"
            VerticalAlignment="Center"
            FontSize="13"
            FontWeight="SemiBold"
            Foreground="{DynamicResource ToolbarTextBrush}"
            Text="{Binding Title}" />
    </codewf:CodeWFWindow.LeftContent>

    <Border Padding="24" Background="{DynamicResource PanelBackgroundBrush}">
        <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" RowSpacing="12">
            <TextBlock
                Classes="heading"
                Text="{Binding Title}"
                TextWrapping="Wrap" />
            <TextBlock
                Grid.Row="1"
                Classes="muted"
                Text="{Binding Message}"
                TextWrapping="Wrap" />

            <Border Grid.Row="2" Classes="confirmationFileList">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Paths}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:DiscardChangesPathItemViewModel">
                                <TextBlock
                                    Classes="monospace"
                                    Margin="0,0,0,6"
                                    Text="{Binding Path}"
                                    TextWrapping="Wrap" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <TextBlock
                Grid.Row="3"
                Classes="warning"
                Text="{Binding Warning}"
                TextWrapping="Wrap" />

            <StackPanel
                Grid.Row="4"
                HorizontalAlignment="Right"
                Orientation="Horizontal"
                Spacing="8">
                <Button
                    MinWidth="86"
                    Command="{Binding CancelCommand}"
                    Content="{Binding CancelText}" />
                <Button
                    Classes="destructive"
                    MinWidth="112"
                    Command="{Binding DiscardCommand}"
                    Content="{Binding DiscardText}" />
            </StackPanel>
        </Grid>
    </Border>
</codewf:CodeWFWindow>
