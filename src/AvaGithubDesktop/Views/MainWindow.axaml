<codewf:CodeWFWindow
    x:Class="AvaGithubDesktop.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:codewf="https://codewf.com"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i18n="https://codewf.com"
    xmlns:l="clr-namespace:AvaGithubDesktop"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:AvaGithubDesktop.Core.Models"
    xmlns:vm="using:AvaGithubDesktop.ViewModels"
    Title="{i18n:I18n {x:Static l:AvaGithubDesktopL.AppTitle}}"
    Width="1220"
    Height="780"
    MinWidth="960"
    MinHeight="620"
    Background="{DynamicResource AppBackgroundBrush}"
    Icon="/Assets/avalonia-logo.ico"
    TitleBarBackground="#24292F"
    TitleBarBorderBrush="#11161C"
    TitleBarForeground="#F3F4F6"
    TitleBarHeight="34"
    WindowStartupLocation="CenterScreen"
    x:DataType="vm:MainWindowViewModel"
    mc:Ignorable="d">

    <codewf:CodeWFWindow.LeftContent>
        <StackPanel Margin="8,0,0,0" Orientation="Horizontal" Spacing="8">
            <TextBlock
                VerticalAlignment="Center"
                FontSize="12"
                FontWeight="SemiBold"
                Foreground="#F3F4F6"
                Text="{i18n:I18n {x:Static l:AvaGithubDesktopL.AppTitle}}" />
            <Menu Classes="titleBar">
                <MenuItem Header="{i18n:I18n {x:Static l:AvaGithubDesktopL.MenuFile}}">
                    <MenuItem Header="{i18n:I18n {x:Static l:AvaGithubDesktopL.MenuAddLocalRepository}}" Command="{Binding BrowseRepositoryCommand}" />
                    <MenuItem Header="{i18n:I18n {x:Static l:AvaGithubDesktopL.MenuRefresh}}" Command="{Binding RefreshRepositoryCommand}" />
                </MenuItem>
                <MenuItem Header="{i18n:I18n {x:Static l:AvaGithubDesktopL.MenuRepository}}">
                    <MenuItem Header="{i18n:I18n {x:Static l:AvaGithubDesktopL.Open}}" Command="{Binding OpenRepositoryCommand}" />
                    <MenuItem Header="{i18n:I18n {x:Static l:AvaGithubDesktopL.Refresh}}" Command="{Binding RefreshRepositoryCommand}" />
                </MenuItem>
                <MenuItem Header="{i18n:I18n {x:Static l:AvaGithubDesktopL.MenuBranch}}" />
                <MenuItem Header="{i18n:I18n {x:Static l:AvaGithubDesktopL.MenuHelp}}">
                    <MenuItem Header="{i18n:I18n {x:Static l:AvaGithubDesktopL.MenuAbout}}" />
                </MenuItem>
            </Menu>
        </StackPanel>
    </codewf:CodeWFWindow.LeftContent>

    <Grid RowDefinitions="Auto,*,Auto">
        <Border
            Grid.Row="0"
            Padding="12,10"
            Background="{DynamicResource PanelBackgroundBrush}"
            BorderBrush="{DynamicResource PanelBorderBrush}"
            BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto" ColumnSpacing="8">
                <TextBlock
                    VerticalAlignment="Center"
                    Classes="section"
                    Text="{i18n:I18n {x:Static l:AvaGithubDesktopL.Repository}}" />
                <TextBox
                    Grid.Column="1"
                    Classes="repositoryPath"
                    PlaceholderText="{i18n:I18n {x:Static l:AvaGithubDesktopL.RepositoryPathWatermark}}"
                    Text="{Binding RepositoryPath, Mode=TwoWay}"
                    />
                <Button
                    Grid.Column="2"
                    Classes="toolbar"
                    Command="{Binding BrowseRepositoryCommand}"
                    Content="{i18n:I18n {x:Static l:AvaGithubDesktopL.Browse}}" />
                <Button
                    Grid.Column="3"
                    Classes="toolbar"
                    Command="{Binding OpenRepositoryCommand}"
                    Content="{i18n:I18n {x:Static l:AvaGithubDesktopL.Open}}" />
                <Button
                    Grid.Column="4"
                    Classes="toolbar"
                    Command="{Binding RefreshRepositoryCommand}"
                    Content="{i18n:I18n {x:Static l:AvaGithubDesktopL.Refresh}}" />
                <ComboBox
                    Grid.Column="5"
                    Width="150"
                    ItemsSource="{Binding Languages}"
                    SelectedItem="{Binding SelectedLanguage, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="models:LanguageOption">
                            <TextBlock Text="{Binding DisplayName}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="360,*">
            <Border
                Grid.Column="0"
                Background="{DynamicResource SidebarBackgroundBrush}"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="0,0,1,0">
                <Grid RowDefinitions="Auto,Auto,*,Auto">
                    <Grid
                        Grid.Row="0"
                        Height="40"
                        ColumnDefinitions="*,*"
                        Background="#F1F4F7">
                        <Button
                            Grid.Column="0"
                            Classes="repositoryTab"
                            Background="{Binding ChangesTabBackground}"
                            Command="{Binding ShowChangesCommand}"
                            Foreground="{Binding ChangesTabForeground}">
                            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="{i18n:I18n {x:Static l:AvaGithubDesktopL.Changes}}" />
                                <Border
                                    MinWidth="18"
                                    Padding="5,1"
                                    Background="#DDEBFA"
                                    CornerRadius="8"
                                    IsVisible="{Binding HasChanges}">
                                    <TextBlock
                                        FontSize="10"
                                        FontWeight="SemiBold"
                                        Text="{Binding ChangedFilesCount}" />
                                </Border>
                            </StackPanel>
                        </Button>
                        <Button
                            Grid.Column="1"
                            Classes="repositoryTab"
                            Background="{Binding HistoryTabBackground}"
                            Command="{Binding ShowHistoryCommand}"
                            Content="{i18n:I18n {x:Static l:AvaGithubDesktopL.History}}"
                            Foreground="{Binding HistoryTabForeground}" />
                    </Grid>

                    <Border
                        Grid.Row="1"
                        Height="36"
                        Padding="12,0"
                        Background="{DynamicResource PanelBackgroundBrush}"
                        BorderBrush="{DynamicResource PanelBorderBrush}"
                        BorderThickness="0,0,0,1"
                        IsVisible="{Binding IsChangesSelected}">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                            <CheckBox
                                VerticalAlignment="Center"
                                IsChecked="{Binding AreAllChangesIncluded, Mode=TwoWay}"
                                IsThreeState="True" />
                            <TextBlock
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                FontWeight="SemiBold"
                                Text="{Binding ChangedFilesHeaderText}"
                                TextTrimming="CharacterEllipsis" />
                            <TextBlock
                                Grid.Column="2"
                                VerticalAlignment="Center"
                                Classes="muted"
                                FontSize="12"
                                Text="{Binding SelectedChangesStatusText}" />
                        </Grid>
                    </Border>

                    <Border
                        Grid.Row="1"
                        Height="36"
                        Padding="12,0"
                        Background="{DynamicResource PanelBackgroundBrush}"
                        BorderBrush="{DynamicResource PanelBorderBrush}"
                        BorderThickness="0,0,0,1"
                        IsVisible="{Binding IsHistorySelected}">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock
                                VerticalAlignment="Center"
                                FontWeight="SemiBold"
                                Text="{i18n:I18n {x:Static l:AvaGithubDesktopL.History}}" />
                            <TextBlock
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Classes="muted"
                                FontSize="12"
                                Text="{Binding HistoryHeaderText}" />
                        </Grid>
                    </Border>

                    <Grid Grid.Row="2" RowDefinitions="*,Auto">
                        <ListBox
                            Grid.Row="0"
                            Classes="changes"
                            IsVisible="{Binding IsChangesSelected}"
                            ItemsSource="{Binding ChangedFiles}">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:GitChangeItemViewModel">
                                    <Border
                                        Height="42"
                                        Padding="10,0">
                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                            <CheckBox
                                                VerticalAlignment="Center"
                                                IsChecked="{Binding IsIncluded, Mode=TwoWay}" />
                                            <TextBlock
                                                Grid.Column="1"
                                                VerticalAlignment="Center"
                                                Text="{Binding Path}"
                                                TextTrimming="CharacterEllipsis" />
                                            <Border
                                                Grid.Column="2"
                                                Padding="7,2"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Background="{Binding StatusBackground}"
                                                CornerRadius="4">
                                                <TextBlock
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Foreground="{Binding StatusForeground}"
                                                    Text="{Binding DisplayStatus}" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <ListBox
                            Grid.Row="0"
                            Classes="history"
                            IsVisible="{Binding IsHistorySelected}"
                            ItemsSource="{Binding HistoryCommits}"
                            SelectedItem="{Binding SelectedCommit, Mode=TwoWay}">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="models:GitCommitItem">
                                    <Border Height="56" Padding="12,6">
                                        <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto">
                                            <TextBlock
                                                FontWeight="SemiBold"
                                                Text="{Binding Summary}"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                Grid.Column="1"
                                                Classes="muted"
                                                FontSize="11"
                                                Text="{Binding ShortSha}" />
                                            <TextBlock
                                                Grid.Row="1"
                                                Classes="muted"
                                                FontSize="12"
                                                Text="{Binding AuthorName}"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                Grid.Row="1"
                                                Grid.Column="1"
                                                Classes="muted"
                                                FontSize="12"
                                                Text="{Binding RelativeDate}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <StackPanel
                            Grid.Row="1"
                            Margin="16"
                            IsVisible="{Binding ShowEmptyRepository}"
                            Spacing="6">
                            <TextBlock Classes="section" Text="{i18n:I18n {x:Static l:AvaGithubDesktopL.NoRepositoryTitle}}" />
                            <TextBlock Classes="muted" Text="{i18n:I18n {x:Static l:AvaGithubDesktopL.NoRepositoryDetail}}" />
                        </StackPanel>
                    </Grid>

                    <Border
                        Grid.Row="3"
                        Padding="12"
                        Background="{DynamicResource PanelBackgroundBrush}"
                        BorderBrush="{DynamicResource PanelBorderBrush}"
                        BorderThickness="0,1,0,0"
                        IsVisible="{Binding IsChangesSelected}">
                        <StackPanel Spacing="8">
                            <TextBox
                                Classes="commitSummary"
                                IsEnabled="{Binding HasRepository}"
                                PlaceholderText="{i18n:I18n {x:Static l:AvaGithubDesktopL.CommitSummaryPlaceholder}}"
                                Text="{Binding CommitSummary, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBox
                                Classes="commitDescription"
                                AcceptsReturn="True"
                                IsEnabled="{Binding HasRepository}"
                                MinHeight="88"
                                PlaceholderText="{i18n:I18n {x:Static l:AvaGithubDesktopL.CommitDescriptionPlaceholder}}"
                                Text="{Binding CommitDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                TextWrapping="Wrap" />
                            <Button
                                HorizontalAlignment="Stretch"
                                Classes="commitButton"
                                Command="{Binding CommitCommand}"
                                Content="{Binding CommitButtonText}"
                                IsEnabled="{Binding CanCommit}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Margin="18" RowDefinitions="Auto,Auto,Auto,*" RowSpacing="14">
                <StackPanel Grid.Row="0" Spacing="4">
                    <TextBlock Classes="section" Text="{i18n:I18n {x:Static l:AvaGithubDesktopL.CurrentRepository}}" />
                    <TextBlock Classes="heading" Text="{Binding RepositoryName}" TextTrimming="CharacterEllipsis" />
                    <TextBlock Classes="muted" Text="{Binding RootPath}" TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <TextBlock
                    Grid.Row="1"
                    Foreground="#A4262C"
                    IsVisible="{Binding HasError}"
                    Text="{Binding ErrorMessage}"
                    TextWrapping="Wrap" />

                <Grid
                    Grid.Row="2"
                    Grid.RowSpan="2"
                    RowDefinitions="Auto,*"
                    RowSpacing="14"
                    IsVisible="{Binding IsChangesSelected}">
                    <UniformGrid Grid.Row="0" Columns="4">
                        <Border Classes="metricCard" Margin="0,0,8,0">
                            <StackPanel Spacing="4">
                                <TextBlock Classes="muted" Text="{i18n:I18n {x:Static l:AvaGithubDesktopL.ChangedFiles}}" />
                                <TextBlock Classes="metric" Text="{Binding ChangedFilesCount}" />
                            </StackPanel>
                        </Border>
                        <Border Classes="metricCard" Margin="4,0,8,0">
                            <StackPanel Spacing="4">
                                <TextBlock Classes="muted" Text="{i18n:I18n {x:Static l:AvaGithubDesktopL.Staged}}" />
                                <TextBlock Classes="metric" Text="{Binding StagedCount}" />
                            </StackPanel>
                        </Border>
                        <Border Classes="metricCard" Margin="4,0,8,0">
                            <StackPanel Spacing="4">
                                <TextBlock Classes="muted" Text="{i18n:I18n {x:Static l:AvaGithubDesktopL.Unstaged}}" />
                                <TextBlock Classes="metric" Text="{Binding UnstagedCount}" />
                            </StackPanel>
                        </Border>
                        <Border Classes="metricCard" Margin="4,0,0,0">
                            <StackPanel Spacing="4">
                                <TextBlock Classes="muted" Text="{i18n:I18n {x:Static l:AvaGithubDesktopL.Untracked}}" />
                                <TextBlock Classes="metric" Text="{Binding UntrackedCount}" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <Grid Grid.Row="1" ColumnDefinitions="1.15*,1.45*" ColumnSpacing="14">
                        <Border Classes="panel" Padding="14" CornerRadius="6">
                            <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="12">
                                <TextBlock Classes="section" Text="{i18n:I18n {x:Static l:AvaGithubDesktopL.Summary}}" />
                                <Grid Grid.Row="1" ColumnDefinitions="110,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="10">
                                    <TextBlock Classes="muted" Text="{i18n:I18n {x:Static l:AvaGithubDesktopL.CurrentBranch}}" />
                                    <TextBlock Grid.Column="1" Text="{Binding CurrentBranch}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Row="1" Classes="muted" Text="{i18n:I18n {x:Static l:AvaGithubDesktopL.Upstream}}" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Upstream}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Row="2" Classes="muted" Text="{i18n:I18n {x:Static l:AvaGithubDesktopL.Remote}}" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding RemoteUrl}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Row="3" Classes="muted" Text="{i18n:I18n {x:Static l:AvaGithubDesktopL.LastCommit}}" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding LastCommit}" TextWrapping="Wrap" />
                                </Grid>
                                <StackPanel Grid.Row="2" IsVisible="{Binding ShowEmptyRepository}" Spacing="6">
                                    <TextBlock Classes="section" Text="{i18n:I18n {x:Static l:AvaGithubDesktopL.NoRepositoryTitle}}" />
                                    <TextBlock Classes="muted" Text="{i18n:I18n {x:Static l:AvaGithubDesktopL.NoRepositoryDetail}}" />
                                </StackPanel>
                                <StackPanel Grid.Row="3" IsVisible="{Binding HasNoChanges}" Spacing="6">
                                    <TextBlock Classes="section" Text="{i18n:I18n {x:Static l:AvaGithubDesktopL.NoChangesTitle}}" />
                                    <TextBlock Classes="muted" Text="{i18n:I18n {x:Static l:AvaGithubDesktopL.NoChangesDetail}}" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Classes="panel" Padding="14" CornerRadius="6">
                            <Grid RowDefinitions="Auto,Auto,*" RowSpacing="10">
                                <TextBlock Classes="section" Text="{i18n:I18n {x:Static l:AvaGithubDesktopL.Changes}}" />
                                <TextBlock Grid.Row="1" Classes="muted" Text="{Binding AheadBehindText}" />
                                <TextBlock
                                    Grid.Row="2"
                                    Classes="muted"
                                    Text="{Binding SelectedChangesStatusText}"
                                    VerticalAlignment="Top" />
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <Grid
                    Grid.Row="2"
                    Grid.RowSpan="2"
                    RowDefinitions="Auto,*"
                    RowSpacing="14"
                    IsVisible="{Binding IsHistorySelected}">
                    <Border Classes="panel" Padding="14" CornerRadius="6">
                        <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
                            <TextBlock Classes="section" Text="{i18n:I18n {x:Static l:AvaGithubDesktopL.SelectedCommit}}" />
                            <TextBlock
                                Grid.Row="1"
                                Classes="heading"
                                FontSize="16"
                                Text="{Binding SelectedCommit.Summary}"
                                TextWrapping="Wrap" />
                            <Grid Grid.Row="2" ColumnDefinitions="90,*,90,*" RowDefinitions="Auto,Auto" RowSpacing="8">
                                <TextBlock Classes="muted" Text="{i18n:I18n {x:Static l:AvaGithubDesktopL.CommitSha}}" />
                                <TextBlock Grid.Column="1" Text="{Binding SelectedCommit.ShortSha}" />
                                <TextBlock Grid.Column="2" Classes="muted" Text="{i18n:I18n {x:Static l:AvaGithubDesktopL.Date}}" />
                                <TextBlock Grid.Column="3" Text="{Binding SelectedCommit.RelativeDate}" />
                                <TextBlock Grid.Row="1" Classes="muted" Text="{i18n:I18n {x:Static l:AvaGithubDesktopL.Author}}" />
                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Grid.ColumnSpan="3"
                                    Text="{Binding SelectedCommit.AuthorDisplay}"
                                    TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" ColumnDefinitions="1.05*,1.5*" ColumnSpacing="14">
                        <Border Classes="panel" Padding="14" CornerRadius="6">
                            <Grid RowDefinitions="Auto,*" RowSpacing="10">
                                <TextBlock Classes="section" Text="{Binding SelectedCommitChangedFilesHeader}" />
                                <ListBox
                                    Grid.Row="1"
                                    Classes="changes"
                                    ItemsSource="{Binding SelectedCommit.Files}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="models:GitCommitFileItem">
                                            <Border Height="38" Padding="8,0">
                                                <Grid ColumnDefinitions="90,*" ColumnSpacing="8">
                                                    <Border
                                                        Padding="7,2"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Center"
                                                        Background="{Binding StatusBackground}"
                                                        CornerRadius="4">
                                                        <TextBlock
                                                            FontSize="11"
                                                            FontWeight="SemiBold"
                                                            Foreground="{Binding StatusForeground}"
                                                            Text="{Binding DisplayStatus}" />
                                                    </Border>
                                                    <TextBlock
                                                        Grid.Column="1"
                                                        VerticalAlignment="Center"
                                                        Text="{Binding Path}"
                                                        TextTrimming="CharacterEllipsis" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Classes="panel" Padding="14" CornerRadius="6">
                            <StackPanel Spacing="8">
                                <TextBlock Classes="section" Text="{i18n:I18n {x:Static l:AvaGithubDesktopL.Summary}}" />
                                <TextBlock Text="{Binding SelectedCommit.Summary}" TextWrapping="Wrap" />
                                <TextBlock Classes="muted" Text="{Binding SelectedCommit.Sha}" TextWrapping="Wrap" />
                                <StackPanel IsVisible="{Binding HasNoHistory}" Spacing="6">
                                    <TextBlock Classes="section" Text="{i18n:I18n {x:Static l:AvaGithubDesktopL.NoHistoryTitle}}" />
                                    <TextBlock Classes="muted" Text="{i18n:I18n {x:Static l:AvaGithubDesktopL.NoHistoryDetail}}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>

        <Border
            Grid.Row="2"
            Padding="10,5"
            Background="{DynamicResource StatusBarBackgroundBrush}"
            BorderBrush="{DynamicResource StatusBarBorderBrush}"
            BorderThickness="0,1,0,0">
            <TextBlock FontSize="12" Text="{Binding StatusBar.StatusText}" />
        </Border>
    </Grid>
</codewf:CodeWFWindow>
