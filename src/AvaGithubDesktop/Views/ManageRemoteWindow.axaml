<codewf:CodeWFWindow
    x:Class="AvaGithubDesktop.Views.ManageRemoteWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:codewf="https://codewf.com"
    xmlns:vm="using:AvaGithubDesktop.ViewModels"
    x:DataType="vm:ManageRemoteWindowViewModel"
    Width="620"
    Height="340"
    MinWidth="560"
    MinHeight="320"
    Background="{DynamicResource PanelBackgroundBrush}"
    CanMaximize="False"
    CanMinimize="False"
    CanResize="False"
    Icon="/Assets/app-logo.ico"
    ShowInTaskbar="False"
    Title="{Binding Title}"
    TitleBarBackground="{DynamicResource ToolbarBackgroundBrush}"
    TitleBarBorderBrush="{DynamicResource ToolbarBorderBrush}"
    TitleBarForeground="{DynamicResource ToolbarTextBrush}"
    TitleBarHeight="34"
    WindowStartupLocation="CenterOwner">

    <codewf:CodeWFWindow.LeftContent>
        <TextBlock
            Margin="12,0,0,0"
            VerticalAlignment="Center"
            FontSize="13"
            FontWeight="SemiBold"
            Foreground="{DynamicResource ToolbarTextBrush}"
            Text="{Binding Title}" />
    </codewf:CodeWFWindow.LeftContent>

    <Border Padding="24" Background="{DynamicResource PanelBackgroundBrush}">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto" RowSpacing="10">
            <TextBlock
                Classes="heading"
                Text="{Binding Title}"
                TextWrapping="Wrap" />

            <TextBlock
                Grid.Row="1"
                Classes="muted"
                Text="{Binding Description}"
                TextWrapping="Wrap" />

            <StackPanel Grid.Row="2" Spacing="5">
                <TextBlock Classes="formLabel" Text="{Binding RemoteNameLabel}" />
                <TextBox
                    Classes="branchNameInput"
                    IsReadOnly="{Binding IsRemoteNameReadOnly}"
                    Text="{Binding RemoteName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <StackPanel Grid.Row="3" Spacing="5">
                <TextBlock Classes="formLabel" Text="{Binding RemoteUrlLabel}" />
                <TextBox
                    Classes="branchNameInput"
                    PlaceholderText="{Binding RemoteUrlWatermark}"
                    Text="{Binding RemoteUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <TextBlock
                Grid.Row="4"
                Classes="warning"
                IsVisible="{Binding HasValidationMessage}"
                Text="{Binding ValidationMessage}"
                TextWrapping="Wrap" />

            <Grid Grid.Row="5" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                <Button
                    Classes="destructive"
                    MinWidth="112"
                    Command="{Binding RemoveCommand}"
                    Content="{Binding RemoveText}"
                    IsVisible="{Binding HasExistingRemote}" />

                <StackPanel
                    Grid.Column="2"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal"
                    Spacing="8">
                    <Button
                        MinWidth="86"
                        Command="{Binding CancelCommand}"
                        Content="{Binding CancelText}" />
                    <Button
                        Classes="dialogPrimary"
                        MinWidth="112"
                        Command="{Binding SaveCommand}"
                        Content="{Binding SaveText}" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</codewf:CodeWFWindow>
