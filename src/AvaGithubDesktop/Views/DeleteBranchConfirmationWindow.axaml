<codewf:CodeWFWindow
    x:Class="AvaGithubDesktop.Views.DeleteBranchConfirmationWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:codewf="https://codewf.com"
    xmlns:vm="using:AvaGithubDesktop.ViewModels"
    x:DataType="vm:DeleteBranchConfirmationWindowViewModel"
    Width="500"
    Height="280"
    MinWidth="460"
    MinHeight="260"
    Background="{DynamicResource PanelBackgroundBrush}"
    CanMaximize="False"
    CanMinimize="False"
    CanResize="False"
    Icon="/Assets/logo.ico"
    ShowInTaskbar="False"
    Title="{Binding Title}"
    TitleBarBackground="{DynamicResource ToolbarBackgroundBrush}"
    TitleBarBorderBrush="{DynamicResource ToolbarBorderBrush}"
    TitleBarForeground="{DynamicResource ToolbarTextBrush}"
    TitleBarHeight="34"
    WindowStartupLocation="CenterOwner">

    <codewf:CodeWFWindow.LeftContent>
        <TextBlock
            Margin="12,0,0,0"
            VerticalAlignment="Center"
            FontSize="13"
            FontWeight="SemiBold"
            Foreground="{DynamicResource ToolbarTextBrush}"
            Text="{Binding Title}" />
    </codewf:CodeWFWindow.LeftContent>

    <Border Padding="24" Background="{DynamicResource PanelBackgroundBrush}">
        <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="14">
            <TextBlock
                Classes="heading"
                Text="{Binding Title}"
                TextWrapping="Wrap" />
            <TextBlock
                Grid.Row="1"
                Classes="muted"
                Text="{Binding Message}"
                TextWrapping="Wrap" />

            <Border Grid.Row="2" Classes="branchBasePanel">
                <TextBlock
                    Classes="monospace"
                    Text="{Binding BranchName}"
                    TextWrapping="Wrap" />
            </Border>

            <Grid Grid.Row="3" ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <TextBlock
                    VerticalAlignment="Center"
                    Classes="warning"
                    Text="{Binding Warning}" />
                <StackPanel
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal"
                    Spacing="8">
                    <Button
                        MinWidth="86"
                        Command="{Binding CancelCommand}"
                        Content="{Binding CancelText}" />
                    <Button
                        Classes="destructive"
                        MinWidth="112"
                        Command="{Binding DeleteCommand}"
                        Content="{Binding DeleteText}" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</codewf:CodeWFWindow>
