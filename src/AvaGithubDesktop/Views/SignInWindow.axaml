<codewf:CodeWFWindow
    x:Class="AvaGithubDesktop.Views.SignInWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:codewf="https://codewf.com"
    xmlns:vm="using:AvaGithubDesktop.ViewModels"
    x:DataType="vm:SignInWindowViewModel"
    Width="520"
    Height="400"
    MinWidth="500"
    MinHeight="380"
    Background="{DynamicResource PanelBackgroundBrush}"
    CanMaximize="False"
    CanMinimize="False"
    CanResize="False"
    Icon="/Assets/logo.ico"
    ShowInTaskbar="False"
    TitleBarBackground="{DynamicResource ToolbarBackgroundBrush}"
    TitleBarBorderBrush="{DynamicResource ToolbarBorderBrush}"
    TitleBarForeground="{DynamicResource ToolbarTextBrush}"
    TitleBarHeight="34"
    WindowStartupLocation="CenterOwner">

    <codewf:CodeWFWindow.LeftContent>
        <TextBlock
            Margin="12,0,0,0"
            VerticalAlignment="Center"
            FontSize="13"
            FontWeight="SemiBold"
            Foreground="{DynamicResource ToolbarTextBrush}"
            Text="{Binding Title}" />
    </codewf:CodeWFWindow.LeftContent>

    <Border Padding="24" Background="{DynamicResource PanelBackgroundBrush}">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="14">
            <TextBlock Classes="heading" Text="{Binding Title}" />
            <TextBlock
                Grid.Row="1"
                Classes="muted"
                Text="{Binding Description}"
                TextWrapping="Wrap" />

            <StackPanel Grid.Row="2" Spacing="6">
                <TextBlock Classes="formLabel" Text="{Binding EndpointLabel}" />
                <TextBox
                    Classes="signInInput"
                    PlaceholderText="{Binding EndpointWatermark}"
                    Text="{Binding Endpoint, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <Border
                Grid.Row="3"
                Classes="confirmationFileList"
                IsVisible="{Binding HasDeviceCode}">
                <StackPanel Spacing="6">
                    <TextBlock Classes="formLabel" Text="{Binding DeviceCodeLabel}" />
                    <TextBlock
                        Classes="monospace"
                        FontSize="20"
                        FontWeight="SemiBold"
                        Text="{Binding UserCode}" />
                    <TextBlock Classes="muted" Text="{Binding DeviceCodeInstructionText}" TextWrapping="Wrap" />
                    <TextBlock Classes="muted" Text="{Binding WaitingForBrowserText}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="4" Spacing="8">
                <TextBlock
                    Classes="warning"
                    IsVisible="{Binding HasError}"
                    Text="{Binding ErrorText}"
                    TextWrapping="Wrap" />
            </StackPanel>

            <Grid Grid.Row="5" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                <Button
                    Grid.Column="1"
                    MinWidth="86"
                    Command="{Binding CancelCommand}"
                    Content="{Binding CancelText}" />
                <Button
                    Grid.Column="2"
                    Classes="signInPrimary"
                    MinWidth="136"
                    Command="{Binding BeginBrowserSignInCommand}"
                    Content="{Binding BrowserButtonDisplayText}" />
            </Grid>
        </Grid>
    </Border>
</codewf:CodeWFWindow>
