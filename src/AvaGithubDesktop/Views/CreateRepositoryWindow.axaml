<codewf:CodeWFWindow
    x:Class="AvaGithubDesktop.Views.CreateRepositoryWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:codewf="https://codewf.com"
    xmlns:i18n="https://codewf.com"
    xmlns:l="clr-namespace:AvaGithubDesktop"
    xmlns:vm="using:AvaGithubDesktop.ViewModels"
    x:DataType="vm:CreateRepositoryWindowViewModel"
    Width="620"
    Height="360"
    MinWidth="560"
    MinHeight="340"
    Background="{DynamicResource PanelBackgroundBrush}"
    CanMaximize="False"
    CanMinimize="False"
    CanResize="False"
    Icon="/Assets/app-logo.ico"
    ShowInTaskbar="False"
    Title="{Binding Title}"
    TitleBarBackground="{DynamicResource ToolbarBackgroundBrush}"
    TitleBarBorderBrush="{DynamicResource ToolbarBorderBrush}"
    TitleBarForeground="{DynamicResource ToolbarTextBrush}"
    TitleBarHeight="34"
    WindowStartupLocation="CenterOwner">

    <codewf:CodeWFWindow.LeftContent>
        <TextBlock
            Margin="12,0,0,0"
            VerticalAlignment="Center"
            FontSize="13"
            FontWeight="SemiBold"
            Foreground="{DynamicResource ToolbarTextBrush}"
            Text="{Binding Title}" />
    </codewf:CodeWFWindow.LeftContent>

    <Border Padding="24" Background="{DynamicResource PanelBackgroundBrush}">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto" RowSpacing="10">
            <TextBlock
                Classes="heading"
                Text="{Binding Title}"
                TextWrapping="Wrap" />

            <StackPanel Grid.Row="1" Spacing="5">
                <TextBlock Classes="formLabel" Text="{Binding RepositoryNameLabel}" />
                <TextBox
                    Classes="branchNameInput"
                    Text="{Binding RepositoryName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <StackPanel Grid.Row="2" Spacing="5">
                <TextBlock Classes="formLabel" Text="{Binding ParentDirectoryLabel}" />
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <TextBox
                        Classes="branchNameInput"
                        Text="{Binding ParentDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <Button
                        Grid.Column="1"
                        MinWidth="86"
                        Command="{Binding BrowseParentDirectoryCommand}"
                        Content="{Binding BrowseButtonText}" />
                </Grid>
            </StackPanel>

            <Border Grid.Row="3" Classes="branchBasePanel">
                <StackPanel Spacing="4">
                    <TextBlock Classes="section" Text="{Binding DestinationPathLabel}" />
                    <TextBlock
                        Classes="muted"
                        Text="{Binding DestinationPath}"
                        TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>

            <TextBlock
                Grid.Row="4"
                Classes="warning"
                IsVisible="{Binding HasValidationMessage}"
                Text="{Binding ValidationMessage}"
                TextWrapping="Wrap" />

            <StackPanel
                Grid.Row="5"
                HorizontalAlignment="Right"
                Orientation="Horizontal"
                Spacing="8">
                <Button
                    MinWidth="86"
                    Command="{Binding CancelCommand}"
                    Content="{i18n:I18n {x:Static l:AvaGithubDesktopL.Cancel}}" />
                <Button
                    Classes="dialogPrimary"
                    MinWidth="112"
                    Command="{Binding CreateCommand}"
                    Content="{i18n:I18n {x:Static l:AvaGithubDesktopL.CreateRepositoryButton}}" />
            </StackPanel>
        </Grid>
    </Border>
</codewf:CodeWFWindow>
