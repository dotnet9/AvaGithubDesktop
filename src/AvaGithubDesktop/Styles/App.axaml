<Styles xmlns="https://github.com/avaloniaui">
    <Style Selector="TextBlock.heading">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
    </Style>

    <Style Selector="TextBlock.section">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
    </Style>

    <Style Selector="TextBlock.muted">
        <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style Selector="TextBlock.metric">
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
    </Style>

    <Style Selector="Border.panel">
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="Border.metricCard">
        <Setter Property="Padding" Value="14" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="Button.toolbar">
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="Padding" Value="12,5" />
    </Style>

    <Style Selector="TextBox.repositoryPath">
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBox.commitSummary">
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBox.commitDescription">
        <Setter Property="MinHeight" Value="88" />
        <Setter Property="AcceptsReturn" Value="True" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style Selector="Button.commitButton">
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Menu.titleBar">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Height" Value="34" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="Menu.titleBar > MenuItem">
        <Setter Property="Foreground" Value="#F3F4F6" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="8,0" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style Selector="Menu.titleBar > MenuItem:pointerover">
        <Setter Property="Background" Value="#32383F" />
    </Style>

    <Style Selector="Menu.titleBar > MenuItem:open">
        <Setter Property="Background" Value="#3A424B" />
    </Style>

    <Style Selector="ListBox.changes">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style Selector="ListBox.changes ListBoxItem">
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>

    <Style Selector="ListBox.changes ListBoxItem:pointerover">
        <Setter Property="Background" Value="#EEF3F8" />
    </Style>

    <Style Selector="ListBox.changes ListBoxItem:selected">
        <Setter Property="Background" Value="#DDEBFA" />
    </Style>
</Styles>
