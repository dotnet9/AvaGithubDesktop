<prism:PrismApplication
    x:Class="AvaGithubDesktop.App"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:codewf="https://codewf.com"
    xmlns:desktopThemes="using:AvaGithubDesktop.Controls.Themes"
    xmlns:local="using:AvaGithubDesktop"
    xmlns:markdownThemes="https://codewf.com"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:semi="https://irihi.tech/semi"
    RequestedThemeVariant="Light">

    <prism:PrismApplication.DataTemplates>
        <local:ViewLocator />
    </prism:PrismApplication.DataTemplates>

    <prism:PrismApplication.Styles>
        <FluentTheme />
        <semi:SemiTheme Locale="zh-CN" />
        <semi:UrsaSemiTheme Locale="zh-CN" />
        <codewf:CodeWFTheme />
        <markdownThemes:MarkdownThemes TypographyTheme="Simple" />
        <desktopThemes:AvaGithubDesktopControlsTheme />
    </prism:PrismApplication.Styles>
</prism:PrismApplication>
