<Styles xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Styles.Resources>
        <x:Double x:Key="MenuFlyoutMaxHeight">Infinity</x:Double>
    </Styles.Resources>

    <Style Selector="Menu.titleBar">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Height" Value="34" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="Menu.titleBar > MenuItem">
        <Setter Property="Foreground" Value="{DynamicResource ToolbarTextBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="8,0" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style Selector="Menu.titleBar > MenuItem:pointerover">
        <Setter Property="Background" Value="{DynamicResource ToolbarHoverBackgroundBrush}" />
    </Style>

    <Style Selector="Menu.titleBar > MenuItem:open">
        <Setter Property="Background" Value="{DynamicResource ToolbarHoverBackgroundBrush}" />
    </Style>
</Styles>
