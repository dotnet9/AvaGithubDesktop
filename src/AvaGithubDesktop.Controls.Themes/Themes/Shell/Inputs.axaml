<Styles xmlns="https://github.com/avaloniaui">
    <Style Selector="Button.toolbar">
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="Padding" Value="12,5" />
    </Style>

    <Style Selector="Button.syncToolbar">
        <Setter Property="MinHeight" Value="38" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.syncDropdownArrow">
        <Setter Property="MinWidth" Value="39" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.accountButton">
        <Setter Property="MinWidth" Value="170" />
        <Setter Property="MinHeight" Value="38" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.branchSelector">
        <Setter Property="MinWidth" Value="190" />
        <Setter Property="MinHeight" Value="38" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.repositorySelector">
        <Setter Property="MinHeight" Value="38" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.toolbarSplit">
        <Setter Property="MinHeight" Value="50" />
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="BorderThickness" Value="0,0,1,0" />
        <Setter Property="BorderBrush" Value="{DynamicResource ToolbarSplitBorderBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource ToolbarTextBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.toolbarSplit:pointerover">
        <Setter Property="Background" Value="{DynamicResource ToolbarHoverBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource ToolbarTextBrush}" />
    </Style>

    <Style Selector="Button.toolbarSplit:disabled">
        <Setter Property="Opacity" Value="0.75" />
    </Style>

    <Style Selector="Button.toolbarSplit PathIcon.toolbarOcticon">
        <Setter Property="Width" Value="16" />
        <Setter Property="Height" Value="16" />
        <Setter Property="Foreground" Value="{DynamicResource ToolbarSecondaryTextBrush}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.toolbarSplit:pointerover PathIcon.toolbarOcticon">
        <Setter Property="Foreground" Value="{DynamicResource ToolbarTextBrush}" />
    </Style>

    <Style Selector="Button.repositoryAdd">
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.repositoryAddMenu">
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
    </Style>

    <Style Selector="Button.repositoryAdd PathIcon.repositoryAddArrow">
        <Setter Property="Width" Value="12" />
        <Setter Property="Height" Value="12" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.syncFlyoutMenu">
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
    </Style>

    <Style Selector="Button.syncFlyoutMenu:pointerover">
        <Setter Property="Background" Value="{DynamicResource HoverBackgroundBrush}" />
    </Style>

    <Style Selector="Button.syncFlyoutMenu PathIcon.syncFlyoutIcon">
        <Setter Property="Width" Value="16" />
        <Setter Property="Height" Value="16" />
        <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="PathIcon.syncBadgeIcon">
        <Setter Property="Width" Value="10" />
        <Setter Property="Height" Value="10" />
        <Setter Property="Foreground" Value="{DynamicResource ToolbarTextBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBox.repositoryPath">
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBox.repositoryFilter">
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBox.changesFilter">
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBox.branchFilter">
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBox.branchNameInput">
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBox.signInInput">
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBox.commitSummary">
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="Padding" Value="9,0" />
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderContrastBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBox.commitDescription">
        <Setter Property="MinHeight" Value="88" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="AcceptsReturn" Value="True" />
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style Selector="TextBox.commitSummary:focus">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
    </Style>

    <Style Selector="TextBox.commitDescription:focus">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
    </Style>

    <Style Selector="TextBox.diffViewer">
        <Setter Property="AcceptsReturn" Value="True" />
        <Setter Property="FontFamily" Value="Cascadia Mono, JetBrains Mono, Consolas, Noto Sans Mono CJK SC, monospace" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextWrapping" Value="NoWrap" />
    </Style>

    <Style Selector="Button.commitButton">
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Foreground" Value="{DynamicResource ToolbarTextBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Button.commitButton:pointerover">
        <Setter Property="Background" Value="{DynamicResource ToolbarHoverBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ToolbarHoverBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource ToolbarTextBrush}" />
    </Style>

    <Style Selector="Button.commitButton:disabled">
        <Setter Property="Background" Value="{DynamicResource PanelBorderBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
        <Setter Property="Opacity" Value="1" />
    </Style>

    <Style Selector="Button.branchCheckout">
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Button.newBranch">
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Button.stashButton">
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Button.stashButton:pointerover">
        <Setter Property="Background" Value="{DynamicResource AccentSubtleBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    </Style>

    <Style Selector="Button.stashButton:disabled">
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
        <Setter Property="Opacity" Value="1" />
    </Style>

    <Style Selector="Button.commitButton TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource ToolbarTextBrush}" />
    </Style>

    <Style Selector="Button.commitButton PathIcon.buttonGlyph">
        <Setter Property="Width" Value="14" />
        <Setter Property="Height" Value="14" />
        <Setter Property="Foreground" Value="{DynamicResource ToolbarTextBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.commitButton:disabled TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
    </Style>

    <Style Selector="Button.commitButton:disabled PathIcon.buttonGlyph">
        <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
    </Style>

    <Style Selector="Button.stashButton TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    </Style>

    <Style Selector="Button.stashButton PathIcon.buttonGlyph">
        <Setter Property="Width" Value="14" />
        <Setter Property="Height" Value="14" />
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.stashButton:disabled TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
    </Style>

    <Style Selector="Button.stashButton:disabled PathIcon.buttonGlyph">
        <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
    </Style>

    <Style Selector="CheckBox.commitOption">
        <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
    </Style>

    <Style Selector="Button.stashAction">
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.inlineAction">
        <Setter Property="MinHeight" Value="24" />
        <Setter Property="Padding" Value="8,2" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.signInPrimary">
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="Padding" Value="12,5" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Button.destructive">
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="Padding" Value="12,5" />
        <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource DangerBorderBrush}" />
        <Setter Property="Background" Value="{DynamicResource DangerSubtleBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Button.dialogPrimary">
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="Padding" Value="12,5" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Button.repositoryTab">
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
        <Setter Property="MinHeight" Value="29" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Button.repositoryTab:pointerover">
        <Setter Property="Background" Value="{DynamicResource HoverBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
    </Style>

    <Style Selector="Button.repositoryTab.selected">
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
    </Style>

    <Style Selector="Border.repositoryTabCountBadge">
        <Setter Property="MinWidth" Value="18" />
        <Setter Property="Padding" Value="5,1" />
        <Setter Property="Background" Value="{DynamicResource AccentSubtleBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>

    <Style Selector="Border.repositoryTabCountBadge TextBlock">
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style Selector="Border.repositoryTabIndicator">
        <Setter Property="Height" Value="3" />
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
    </Style>

    <Style Selector="ComboBox.toolbarLanguage">
        <Setter Property="MinHeight" Value="50" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="BorderThickness" Value="0,0,1,0" />
        <Setter Property="BorderBrush" Value="{DynamicResource ToolbarSplitBorderBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource ToolbarTextBrush}" />
        <Setter Property="Padding" Value="10,0" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
</Styles>
