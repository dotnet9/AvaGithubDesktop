<Styles xmlns="https://github.com/avaloniaui">
    <Style Selector="Border.panel">
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="Border.metricCard">
        <Setter Property="Padding" Value="12" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="Border.branchFlyout">
        <Setter Property="Padding" Value="12" />
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
    </Style>

    <Style Selector="Border.repositoryFlyout">
        <Setter Property="Padding" Value="10" />
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
    </Style>

    <Style Selector="Border.accountFlyout">
        <Setter Property="Padding" Value="12" />
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
    </Style>

    <Style Selector="Border.stashBanner">
        <Setter Property="Padding" Value="10" />
        <Setter Property="Background" Value="#FFF8E5" />
        <Setter Property="BorderBrush" Value="#E7C36A" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
    </Style>

    <Style Selector="Border.confirmationFileList">
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="Background" Value="{DynamicResource PanelAltBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
    </Style>

    <Style Selector="Border.toolbarBand">
        <Setter Property="Height" Value="50" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="{DynamicResource ToolbarBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ToolbarBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>

    <Style Selector="Border.tabBand">
        <Setter Property="Height" Value="29" />
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>

    <Style Selector="Grid.tabBand">
        <Setter Property="Height" Value="29" />
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
    </Style>

    <Style Selector="Border.changesHeader">
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="Background" Value="{DynamicResource PanelAltBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>

    <Style Selector="Border.commitArea">
        <Setter Property="Padding" Value="10" />
        <Setter Property="Background" Value="{DynamicResource PanelAltBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,1,0,0" />
    </Style>

    <Style Selector="Border.diffHeader">
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="Background" Value="{DynamicResource PanelAltBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>

    <Style Selector="Border.historySurface">
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
    </Style>

    <Style Selector="Border.historySummary">
        <Setter Property="Padding" Value="12" />
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>

    <Style Selector="Border.historyFileColumn">
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,1,0" />
    </Style>

    <Style Selector="Border.historyFileHeader">
        <Setter Property="Height" Value="30" />
        <Setter Property="Padding" Value="10,0" />
        <Setter Property="Background" Value="{DynamicResource PanelAltBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>
</Styles>
