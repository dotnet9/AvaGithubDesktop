<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F5F6F8" />
            <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="PanelBorderBrush" Color="#D8DEE6" />
            <SolidColorBrush x:Key="PrimaryTextBrush" Color="#24292F" />
            <SolidColorBrush x:Key="SecondaryTextBrush" Color="#57606A" />
            <SolidColorBrush x:Key="MutedTextBrush" Color="#6E7781" />
            <SolidColorBrush x:Key="AccentBrush" Color="#0969DA" />
            <SolidColorBrush x:Key="DangerBrush" Color="#CF222E" />
            <SolidColorBrush x:Key="DangerSubtleBrush" Color="#FFF5F5" />
            <SolidColorBrush x:Key="DangerBorderBrush" Color="#FFD6D6" />
            <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#EBEEF2" />
            <SolidColorBrush x:Key="StatusBarBackgroundBrush" Color="#F0F2F5" />
            <SolidColorBrush x:Key="StatusBarBorderBrush" Color="#D8DEE6" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <FontFamily x:Key="ContentControlThemeFontFamily">Inter, Microsoft YaHei UI, Segoe UI</FontFamily>
    <FontFamily x:Key="ControlContentThemeFontFamily">Inter, Microsoft YaHei UI, Segoe UI</FontFamily>
    <x:Double x:Key="ControlContentThemeFontSize">13</x:Double>
</ResourceDictionary>
