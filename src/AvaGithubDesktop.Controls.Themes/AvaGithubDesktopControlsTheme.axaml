<Styles
    x:Class="AvaGithubDesktop.Controls.Themes.AvaGithubDesktopControlsTheme"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Styles.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="Themes/Shared/Palette.axaml" />
                <ResourceInclude Source="Themes/Controls/UnifiedDiffViewer.axaml" />
                <ResourceInclude Source="Themes/Controls/OperationLogView.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Styles.Resources>

    <StyleInclude Source="Themes/Controls/ImageDiffViewer.axaml" />
    <StyleInclude Source="Themes/Shell/Text.axaml" />
    <StyleInclude Source="Themes/Shell/Panels.axaml" />
    <StyleInclude Source="Themes/Shell/Inputs.axaml" />
    <StyleInclude Source="Themes/Shell/Menus.axaml" />
    <StyleInclude Source="Themes/Shell/Lists.axaml" />
</Styles>
